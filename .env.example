# Generate with: openssl rand -hex 32
JWT_SECRET=

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── 3dprintlog API ──────────────────────────────────────────────────────────
# Base URL for the 3dprintlog API
PRINTLOG_API_URL=https://api.3dprintlog.com

# ── OAuth2 (optional — fill in when you get credentials from hello@3dprintlog.com) ──
# PRINTLOG_OAUTH_CLIENT_ID=
# PRINTLOG_OAUTH_CLIENT_SECRET=
# PRINTLOG_OAUTH_AUTH_URL=
# PRINTLOG_OAUTH_TOKEN_URL=
# PRINTLOG_OAUTH_SCOPE=api1

# Public app URL (used to build the MCP config snippet shown to users)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
